# VED environment — copy to .env and adjust. `./ved.sh` auto-creates .env from this.

# --- Postgres ---
POSTGRES_USER=ved
POSTGRES_PASSWORD=ved
POSTGRES_DB=ved
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- NATS / JetStream ---
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=ved
MINIO_ROOT_PASSWORD=ved-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Application ---
CONTROLPLANE_PORT=8080
NODE_PORT=8091
WEB_PORT=5173

# --- Secrets (CHANGE THESE in any real deployment) ---
# Signs M1 access + refresh JWTs. Use a long random value in production
# (e.g. `openssl rand -hex 32`). A node mints a stable secret at provisioning (M6).
JWT_SECRET=dev-insecure-secret-change-me

# --- Dev convenience ---
# DEV_SEED=true idempotently creates a demo tenant + admin (admin@ved.local /
# admin1234) on node startup so login works before control-plane provisioning (M4).
# Set to false for any real deployment.
DEV_SEED=true
